{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://web2app.local/schemas/page-map.schema.json",
  "title": "Page Map",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "productId", "version", "pages"],
  "properties": {
    "id": { "type": "string", "minLength": 2 },
    "productId": { "type": "string", "minLength": 2 },
    "version": { "type": "string", "minLength": 1 },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/page" }
    }
  },
  "$defs": {
    "option": {
      "type": "object",
      "additionalProperties": true,
      "required": ["value"],
      "properties": {
        "value": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "labelIntent": { "type": "string", "minLength": 1 },
        "icon": { "type": "string", "minLength": 2 },
        "assetRequirement": {
          "type": "object",
          "additionalProperties": true
        },
        "exclusive": { "type": "boolean" }
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "pageType", "conversionPurpose"],
      "properties": {
        "id": { "type": "string", "minLength": 2 },
        "pageType": { "type": "string", "minLength": 2 },
        "variant": { "type": "string", "minLength": 2 },
        "module": { "type": "string", "minLength": 2 },
        "conversionPurpose": { "type": "string", "minLength": 8 },
        "dataKey": { "type": "string", "minLength": 2 },
        "title": { "type": "string", "minLength": 1 },
        "question": { "type": "string", "minLength": 1 },
        "titleIntent": { "type": "string", "minLength": 2 },
        "sectionId": { "type": "string", "minLength": 1 },
        "sectionLabel": { "type": "string", "minLength": 1 },
        "sectionOrder": { "type": "integer", "minimum": 0 },
        "trustPurpose": { "type": "string", "minLength": 2 },
        "paywallBridgeRole": { "type": "string", "minLength": 2 },
        "positionRequirement": { "type": "string", "minLength": 2 },
        "measurementType": {
          "type": "string",
          "enum": ["height", "weight", "target_weight", "waist", "generic"]
        },
        "units": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "defaultUnit": { "type": "string", "minLength": 1 },
        "designOverride": {
          "type": "object",
          "additionalProperties": true
        },
        "assetRequirement": {
          "type": "object",
          "additionalProperties": true
        },
        "influences": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["summary", "analysis", "plan", "paywall", "segmentation", "analytics"]
          }
        },
        "minSelections": { "type": "integer", "minimum": 0 },
        "allowEmptySelection": { "type": "boolean" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/option" }
        }
      }
    }
  }
}
