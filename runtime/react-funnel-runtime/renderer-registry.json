{
  "version": "0.1.0",
  "selection": "pageType + variant",
  "renderers": [
    {
      "key": "entry_page",
      "component": "EntryPage",
      "status": "required",
      "figmaTemplateRequired": true,
      "notes": "First portal screen with large hero image, start CTA, and login button."
    },
    {
      "key": "intro_page",
      "component": "IntroPage",
      "status": "required",
      "figmaTemplateRequired": true,
      "notes": "Copy-only transition page used between major OB sections."
    },
    {
      "key": "single_choice_page:image_grid",
      "component": "SingleChoicePage",
      "status": "required",
      "figmaTemplateRequired": true,
      "notes": "Image-led single choice cards. Used for age_group, body type, or other visual self-identification questions."
    },
    {
      "key": "single_choice_page:plain_list",
      "component": "SingleChoicePage",
      "status": "required",
      "figmaTemplateRequired": true,
      "notes": "Text-only single choice rows. Does not require icons or images."
    },
    {
      "key": "single_choice_page:icon_list",
      "component": "SingleChoicePage",
      "status": "required",
      "figmaTemplateRequired": true,
      "notes": "Single choice rows with semantic Lucide icons."
    },
    {
      "key": "multi_choice_page:image_grid",
