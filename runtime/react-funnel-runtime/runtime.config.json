{
  "version": "0.1.0",
  "id": "react-funnel-runtime",
  "name": "React Funnel Runtime",
  "purpose": "A fixed React execution layer that renders Web2App funnels from generated config instead of rebuilding app logic from scratch for every product.",
  "sourceInputs": {
    "funnelConfig": "outputs/config/funnel.config.json",
    "theme": "outputs/design/theme.json",
    "designHandoff": "outputs/design-handoff/design-handoff.json",
    "designTemplateMap": "outputs/design-handoff/page-type-template-map.json"
  },
  "outputTarget": "outputs/app",
  "renderSelection": {
    "primaryKey": "pageType",
    "secondaryKey": "variant",
    "fallback": "pageType"
  },
  "navigationBehaviorSource": "runtime/react-funnel-runtime/adapters/navigation-behavior.spec.json",
  "backendIntegrationSource": "runtime/react-funnel-runtime/adapters/backend-integration.spec.json",
  "designRulesSource": "global-rules/design-rules.json",
  "coreCapabilities": [
    "linear and conditional funnel navigation",
    "segmented top progress by OB section",
    "answer storage by dataKey",
    "local-first Firestore answer persistence",
    "per-page validation",
    "mobile-first layout with desktop Web2App layout, not a phone mockup",
    "theme token application",
    "Design handoff template map reference",
    "height and weight unit conversion",
    "Stripe Embedded Checkout through backend-created clientSecret",
    "billing resolve/offers API with mock display fallback",
    "anonymous backend identity via billing API",
    "subscription and entitlement verification after Stripe return",
    "returning user login",
    "account and subscription management",
    "subscription cancellation only when the API reference exposes a frontend cancel endpoint",
    "post-purchase anonymous account upgrade"
  ],
  "billingApiAdapter": {
    "baseUrlEnv": "VITE_BILLING_API_BASE_URL",
    "defaultBaseUrl": "https://billing-dev.cloud.7mfitness.com",
    "appCodeEnv": "VITE_BILLING_APP_CODE",
    "stripePublishableKeyEnv": "VITE_STRIPE_PUBLISHABLE_KEY",
    "resolveOffersEndpoint": "/billing/{appCode}/v1/paywalls/resolve/offers?placementCode={placementCode}",
    "resolveOffersAuth": "none",
    "placementCodeSource": "URL query lpid first, then explicit runtime placementCode",
    "anonymousUserEndpoint": "/billing/{appCode}/v1/users/anonymous",
    "anonymousUserAuth": "none",
    "registerEmailUserEndpoint": "/billing/{appCode}/v1/users/register-from-anonymous",
    "loginEmailUserEndpoint": "/billing/{appCode}/v1/users/login",
    "userUpsertEndpoint": "/billing/{appCode}/v1/users/current",
    "stripeEmbeddedCheckoutEndpoint": "/billing/{appCode}/v1/checkout/stripe/embedded-session",
    "subscriptionStatusEndpoint": "/billing/{appCode}/v1/subscriptions/status?uid={uid}",
    "subscriptionListEndpoint": "/billing/{appCode}/v1/subscriptions?uid={uid}",
    "entitlementsEndpoint": "/billing/{appCode}/v1/entitlements?uid={uid}",
    "templateEmailEndpoint": "/billing/{appCode}/v1/emails/template",
    "fallback": "Render API-ready mock plans and visible API error state when the billing service is unavailable.",
    "frontendRecommendedProductsEndpoint": "/billing/{appCode}/v1/paywalls/resolve/offers?placementCode={placementCode}"
  },
  "themeContract": "runtime/react-funnel-runtime/contracts/theme.contract.json",
  "runtimeModules": [
    "FunnelApp",
    "rendererRegistry",
    "answerStore",
    "sectionProgress",
    "navigation",
    "validation",
    "unitConversion",
    "themeAdapter",
    "designHandoffAdapter",
    "analyticsAdapter",
    "apiAdapter"
  ]
}
