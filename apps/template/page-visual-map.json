{
  "version": "runtime-default",
  "defaults": {
    "pageMaxWidth": 420,
    "desktopMaxWidth": 760,
    "background": "var(--bg)",
    "titleAlign": "center",
    "selectedStyle": "primary_outline_or_fill",
    "motion": "subtle"
  },
  "pageTypes": {
    "intro_page": {
      "supportedVariants": [
        "image_top",
        "editorial",
        "proof_panel"
      ],
      "ctaMode": "sticky_bottom"
    },
    "single_choice_page": {
      "supportedVariants": [
        "image_grid",
        "plain_list",
        "icon_list",
        "bottom_image"
      ],
      "ctaMode": "auto_advance"
    },
    "multi_choice_page": {
      "supportedVariants": [
        "image_grid",
        "plain_list",
        "icon_list",
        "bottom_image"
      ],
      "ctaMode": "sticky_bottom",
      "minSelectionFeedback": "disabled_cta"
    },
    "paywall_page": {
      "supportedVariants": [
        "transformation_first",
        "proof_first",
        "app_preview_first"
      ],
      "layout": "long_vertical_sales_page",
      "desktopLayout": "vertical_centered_not_split"
    },
    "summary_page": {
      "supportedVariants": [
        "bmi_profile",
        "body_comparison",
        "clinical_readout"
      ],
      "ctaMode": "sticky_bottom"
    }
  },
  "pages": {}
}
